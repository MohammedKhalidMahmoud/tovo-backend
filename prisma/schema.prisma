generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
//  ENUMS
// ─────────────────────────────────────────────

enum Role {
  customer
  driver
  admin
}

enum TripStatus {
  searching
  matched
  on_way
  in_progress
  completed
  cancelled
}

enum CommissionType {
  fixed_amount
  percentage
  tiered_fixed
  tiered_percentage
}

enum TransactionType {
  credit
  debit
}

enum SupportTicketStatus {
  open
  in_progress
  resolved
  closed
}

// ─────────────────────────────────────────────
//  USER  (core actor fields)
// ─────────────────────────────────────────────

model User {
  id              String    @id @default(uuid())
  name            String
  email           String    @unique
  phone           String?   @unique
  passwordHash    String?
  googleId        String?   @unique
  facebookId      String?   @unique
  appleId         String?   @unique
  avatarUrl       String?
  role            Role      @default(customer)
  isVerified      Boolean   @default(false)
  language        String    @default("en")
  notificationsEnabled Boolean @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // ── Driver-only fields (null for customers) ───────────────────────────────
  // ── Relations ─────────────────────────────────────────────────────────────
  driverProfile   DriverProfile?
  vehicle         Vehicle?
  wallet          Wallet?
  savedAddresses  SavedAddress[]
  tripsAsCustomer Trip[]          @relation("CustomerTrips")
  tripsAsDriver   Trip[]          @relation("DriverTrips")
  ratingsGiven    Rating[]        @relation("CustomerRatings")
  ratingsReceived Rating[]        @relation("DriverRatings")
  insuranceCards  InsuranceCard[]
  notifications   Notification[]
  supportTickets  SupportTicket[]
  deviceTokens    DeviceToken[]
  otps            Otp[]
  refreshTokens   RefreshToken[]
  sosAlerts       SosAlert[]

  @@map("users")
}

model DriverProfile {
  id                String   @id @default(uuid())
  userId            String   @unique
  drivingLicense    String?
  licenseExpiryDate DateTime?
  isOnline          Boolean  @default(false)
  rating            Float    @default(0)
  totalTrips        Int      @default(0)
  serviceId         String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  service Service? @relation(fields: [serviceId], references: [id])

  @@index([serviceId], map: "driver_profiles_serviceId_fkey")
  @@map("driver_profiles")
}

// ─────────────────────────────────────────────
//  VEHICLE
// ─────────────────────────────────────────────

model VehicleModel {
  id          String    @id @default(uuid())
  name        String    @unique
  brand       String
  description String?
  imageUrl    String?
  serviceId   String
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  service  Service?  @relation(fields: [serviceId], references: [id])
  vehicles Vehicle[]

  @@map("vehicle_models")
}

model Vehicle {
  id             String        @id @default(uuid())
  userId         String        @unique
  vehicleModelId String?
  vin            String        @unique
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  user         User          @relation(fields: [userId], references: [id])
  vehicleModel VehicleModel? @relation(fields: [vehicleModelId], references: [id])

  @@map("vehicles")
}

// ─────────────────────────────────────────────
//  WALLET
// ─────────────────────────────────────────────

model Wallet {
  id          String    @id @default(uuid())
  userId      String    @unique
  balance     Decimal   @default(0) @db.Decimal(10, 2)
  currency    String    @default("EGP")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions WalletTransaction[]

  @@map("wallets")
}

model WalletTransaction {
  id        String          @id @default(uuid())
  walletId  String
  type      TransactionType
  amount    Decimal         @db.Decimal(10, 2)
  reason    String
  tripId    String?
  createdAt DateTime        @default(now())

  wallet    Wallet          @relation(fields: [walletId], references: [id])
  trip      Trip?           @relation(fields: [tripId], references: [id])

  @@map("wallet_transactions")
}

// ─────────────────────────────────────────────
//  TRIP
// ─────────────────────────────────────────────

model Trip {
  id              String      @id @default(uuid())
  userId          String
  driverId        String?
  serviceId       String?
  couponId        String?
  couponCode      String?
  status          TripStatus  @default(searching)
  pickupLat       Float
  pickupLng       Float
  pickupAddress   String
  dropoffLat      Float
  dropoffLng      Float
  dropoffAddress  String
  paymentType     String?
  finalFare       Decimal?    @map("fare") @db.Decimal(10, 2)
  originalFare    Decimal?    @map("fareBeforeDiscount") @db.Decimal(10, 2)
  discountAmount  Decimal     @default(0) @db.Decimal(10, 2)
  commission      Decimal?    @db.Decimal(10, 2)
  driverEarnings  Decimal?    @db.Decimal(10, 2)
  currency        String      @default("EGP")
  distanceKm      Float?
  durationMinutes Int?
  shareToken      String?     @unique
  shareTokenExpiresAt DateTime?
  senderConfirmationCode   String?
  receiverConfirmationCode String?
  startedAt       DateTime?
  endedAt         DateTime?
  cancelledAt     DateTime?
  cancelledBy     String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  user            User           @relation("CustomerTrips", fields: [userId], references: [id])
  driver          User?          @relation("DriverTrips", fields: [driverId], references: [id])
  service         Service?       @relation(fields: [serviceId], references: [id])
  coupon          Coupon?        @relation(fields: [couponId], references: [id])
  rating              Rating?
  stops               TripStop[]
  declines            TripDecline[]
  walletTransactions  WalletTransaction[]
  commissionLog       CommissionLog?

  @@index([userId], map: "trips_userId_fkey")
  @@index([driverId], map: "trips_driverId_fkey")
  @@index([couponId])
  @@index([status])
  @@map("trips")
}

model TripStop {
  id        String    @id @default(uuid())
  tripId    String
  order     Int
  lat       Float
  lng       Float
  address   String
  arrivedAt DateTime?

  trip      Trip      @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@unique([tripId, order])
  @@index([tripId])
  @@map("trip_stops")
}

model TripDecline {
  tripId    String
  driverId  String
  createdAt DateTime @default(now())

  trip      Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@id([tripId, driverId])
  @@map("trip_declines")
}

// ─────────────────────────────────────────────
//  RATING
// ─────────────────────────────────────────────

model Rating {
  id        String    @id @default(uuid())
  tripId    String    @unique
  userId    String
  driverId  String
  stars     Int
  comment   String?
  createdAt DateTime  @default(now())

  trip      Trip      @relation(fields: [tripId], references: [id])
  user      User      @relation("CustomerRatings", fields: [userId], references: [id])
  driver    User      @relation("DriverRatings", fields: [driverId], references: [id])

  @@index([driverId], map: "ratings_driverId_fkey")
  @@map("ratings")
}

// ─────────────────────────────────────────────
//  PROMOTIONS / COUPONS
// ─────────────────────────────────────────────

model Promotion {
  id            String    @id @default(uuid())
  title         String
  description   String?
  discountPct   Int
  imageUrl      String?
  validUntil    DateTime?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())

  @@map("promotions")
}

enum DiscountType {
  percentage
  amount
}

model Coupon {
  id                        String       @id @default(uuid())
  code                      String       @unique
  discount_type             DiscountType @default(percentage)
  discount                  Decimal      @db.Decimal(10, 2)
  expiry_date               DateTime?
  usage_limit               Int?
  usage_limit_per_rider     Int?
  min_amount                Decimal?     @db.Decimal(10, 2)
  max_discount              Decimal?     @db.Decimal(10, 2)
  coupon_type               String       @default("all")
  status                    Int          @default(1)
  used_count                Int          @default(0)
  createdAt                 DateTime     @default(now())
  trips                     Trip[]

  @@map("coupons")
}

// ─────────────────────────────────────────────
//  SAVED ADDRESS
// ─────────────────────────────────────────────

model SavedAddress {
  id        String    @id @default(uuid())
  userId    String
  label     String
  address   String
  lat       Float
  lng       Float
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user      User      @relation(fields: [userId], references: [id])

  @@map("saved_addresses")
}

// ─────────────────────────────────────────────
// ─────────────────────────────────────────────

// ─────────────────────────────────────────────
//  NOTIFICATIONS
// ─────────────────────────────────────────────

model Notification {
  id        String    @id @default(uuid())
  userId    String
  title     String
  body      String
  isRead    Boolean   @default(false)
  createdAt DateTime  @default(now())

  user      User      @relation(fields: [userId], references: [id])

  @@index([userId], map: "notifications_userId_fkey")
  @@map("notifications")
}

model SystemSetting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("system_settings")
}

model AdminUser {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  role         String
  passwordHash String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("admin_users")
}

model DeviceToken {
  id        String    @id @default(uuid())
  userId    String
  token     String    @unique
  platform  String
  createdAt DateTime  @default(now())

  user      User      @relation(fields: [userId], references: [id])

  @@index([userId], map: "device_tokens_userId_fkey")
  @@map("device_tokens")
}

// ─────────────────────────────────────────────
//  SUPPORT
// ─────────────────────────────────────────────

model SupportTicket {
  id        String              @id @default(uuid())
  userId    String
  subject   String
  status    SupportTicketStatus @default(open)
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  user      User                @relation(fields: [userId], references: [id])
  messages  TicketMessage[]

  @@map("support_tickets")
}

model TicketMessage {
  id        String        @id @default(uuid())
  ticketId  String
  senderId  String
  body      String        @db.Text
  createdAt DateTime      @default(now())

  ticket    SupportTicket @relation(fields: [ticketId], references: [id])

  @@map("ticket_messages")
}

// ─────────────────────────────────────────────
//  AUTH HELPERS
// ─────────────────────────────────────────────

model Otp {
  id        String    @id @default(uuid())
  userId    String?
  phone     String
  code      String
  expiresAt DateTime
  isUsed    Boolean   @default(false)
  createdAt DateTime  @default(now())

  user      User?     @relation(fields: [userId], references: [id])

  @@map("otps")
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String?
  token     String    @db.Text
  expiresAt DateTime
  createdAt DateTime  @default(now())

  user      User?     @relation(fields: [userId], references: [id])

  @@map("refresh_tokens")
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  email     String
  code      String
  expiresAt DateTime
  isUsed    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("password_reset_tokens")
}

// ─────────────────────────────────────────────
//  INSURANCE (Driver)
// ─────────────────────────────────────────────

model InsuranceCard {
  id           String    @id @default(uuid())
  userId       String
  provider     String
  policyNumber String
  expiresAt    DateTime
  createdAt    DateTime  @default(now())

  user         User      @relation(fields: [userId], references: [id])

  @@map("insurance_cards")
}

// ─────────────────────────────────────────────
//  FAQ
// ─────────────────────────────────────────────

model Faq {
  id        String   @id @default(uuid())
  question  String   @db.Text
  answer    String   @db.Text
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("faqs")
}

// ─────────────────────────────────────────────
//  SOS ALERT
// ─────────────────────────────────────────────

model SosAlert {
  id         String    @id @default(uuid())
  userId     String?
  lat        Float?
  lng        Float?
  message    String?
  status     String    @default("pending")
  resolvedAt DateTime?
  createdAt  DateTime  @default(now())

  user       User?     @relation(fields: [userId], references: [id])

  @@map("sos_alerts")
}

// ─────────────────────────────────────────────
//  REGION
// ─────────────────────────────────────────────

model Region {
  id        String   @id @default(uuid())
  name      String
  city      String?
  lat       Float?
  lng       Float?
  radius    Float?
  status    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("regions")
}

// ─────────────────────────────────────────────
//  SERVICE (ride/delivery type)
// ─────────────────────────────────────────────

model TollGate {
  id        String   @id @default(uuid())
  name      String
  lat       Float
  lng       Float
  fee       Decimal  @db.Decimal(10, 2)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("toll_gates")
}

model Service {
  id                   String   @id @default(uuid())
  name                 String   @unique
  baseFare             Decimal  @default(0) @db.Decimal(10, 2)
  fixedSurcharge       Decimal  @default(0) @db.Decimal(10, 2)
  perStopSurcharge     Decimal  @default(0) @db.Decimal(10, 2)
  imageUrl             String?  @db.Text
  isActive             Boolean  @default(true)
  requiresSenderCode   Boolean? @default(false)
  requiresReceiverCode Boolean? @default(false)
  maxWeightKg          Float?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  trips           Trip[]
  vehicleModels   VehicleModel[]
  driverProfiles  DriverProfile[]
  commissionLogs  CommissionLog[]

  @@map("services")
}

// ─────────────────────────────────────────────
//  COMMISSION RULES
// ─────────────────────────────────────────────

model CommissionRule {
  id        String         @id @default(uuid())
  name      String
  type      CommissionType
  status    Boolean        @default(false)
  config    Json
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@map("commission_rules")
}

// ─────────────────────────────────────────────
//  COMMISSION LOG (platform earnings per trip)
// ─────────────────────────────────────────────

model CommissionLog {
  id          String   @id @default(uuid())
  tripId      String   @unique
  amount      Decimal  @db.Decimal(10, 2)
  paymentType String
  serviceId   String?
  createdAt   DateTime @default(now())

  trip        Trip     @relation(fields: [tripId], references: [id])
  service     Service? @relation(fields: [serviceId], references: [id])

  @@map("commission_logs")
}
